<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:cardUseCompatPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="@drawable/a">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/libraryName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/item_lib_tv_name_placeholder"
                android:textColor="#D9D8FF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/jura_font_wght" />

            <Switch
                android:id="@+id/librarySwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:background="?attr/selectableItemBackgroundBorderless" />

        </LinearLayout>

        <TextView
            android:id="@+id/libraryDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/item_lib_tv_desc_placeholder"
            android:textColor="#D9D8FF"
            android:textSize="13sp"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/jura_font_wght" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:layout_marginTop="6dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/libraryWordCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/item_lib_tv_word_count_placeholder"
                    android:textColor="#625fba"
                    android:textSize="11sp"
                    android:background="@drawable/tag_bg"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:fontFamily="@font/jura_font_wght" />

                <TextView
                    android:id="@+id/libraryCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/item_lib_tv_category_placeholder"
                    android:textColor="#625fba"
                    android:textSize="11sp"
                    android:background="@drawable/tag_bg"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:layout_marginStart="6dp"
                    android:fontFamily="@font/jura_font_wght" />

                <TextView
                    android:id="@+id/librarySubcategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#625fba"
                    android:textSize="11sp"
                    android:background="@drawable/tag_bg"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:layout_marginStart="6dp"
                    android:fontFamily="@font/jura_font_wght" />

            </LinearLayout>

            <ImageButton
                android:id="@+id/manageButton"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_font_settings"
                app:tint="#FA9085"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>