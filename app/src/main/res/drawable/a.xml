<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#9C95EF"
                android:centerColor="#FCA5A5"
                android:endColor="#E37A72"
                android:angle="70"
                android:type="linear" />
            <corners android:radius="10dp" />
        </shape>
    </item>

    <item
        android:left="1.5dp"
        android:top="1.5dp"
        android:right="1.5dp"
        android:bottom="1.5dp">
        <shape android:shape="rectangle">
            <solid android:color="#302631" />
            <corners android:radius="8.5dp" /> <stroke
            android:width="1dp"
            android:color="#302631" />
        </shape>
    </item>

</layer-list>